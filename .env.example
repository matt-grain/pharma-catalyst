# Google API Key for Gemini
GOOGLE_API_KEY=your-key-here

# LLM Model (optional, defaults to gemini-3-flash-preview)
# Options: gemini/gemini-3-flash-preview, gemini/gemini-2.0-flash, gemini/gemini-1.5-pro
LLM_MODEL=gemini/gemini-3-flash-preview

# NCBI API Key (optional, boosts PubMed from 3 to 10 req/s)
# Get free key at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
